<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/feedFragment">

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.example.recipebookappandorid.ui.feed.FeedFragment"
        android:label="Feed" />

    <fragment
        android:id="@+id/addRecipeFragment"
        android:name="com.example.recipebookappandorid.ui.recipes.AddRecipeFragment"
        android:label="Add Recipe" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.recipebookappandorid.ui.profile.ProfileFragment"
        android:label="Profile">

        <action
            android:id="@+id/action_profileFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.recipebookappandorid.ui.profile.EditProfileFragment"
        android:label="Edit Profile" />

</navigation>